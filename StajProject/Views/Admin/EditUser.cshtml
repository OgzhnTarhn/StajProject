@model StajProject.Models.RegisterModel

@{
    ViewBag.Title = "Kullanıcıyı Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card shadow rounded-4 border-0">
                <div class="card-body p-5">
                    <h3 class="text-center mb-4 fw-bold">Kullanıcıyı Düzenle</h3>

                    @if (!string.IsNullOrEmpty(ViewBag.Message))
                    {
                        <div class="alert alert-success text-center mb-3">@ViewBag.Message</div>
                    }
                    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
                    {
                        <div class="alert alert-danger text-center mb-3">@ViewBag.ErrorMessage</div>
                    }

                    @using (Html.BeginForm())
                    {
                        @Html.HiddenFor(m => m.Username) <!-- Kullanıcı adını gizli yolla göndermek güvenlik için mantıklı -->
                        <div class="mb-3">
                            @Html.Label("Kullanıcı Adı", htmlAttributes: new { @class = "form-label" })
                            <input type="text" class="form-control" value="@Model.Username" disabled />
                        </div>
                        <div class="mb-3">
                            @Html.LabelFor(m => m.Role, "Rol", new { @class = "form-label" })
                            @Html.DropDownListFor(m => m.Role,
                                new SelectList(new[] {
                                    new { Value = "U", Text = "Kullanıcı" },
                                    new { Value = "A", Text = "Admin" }
                                }, "Value", "Text", Model.Role),
                                "Rol seçin", new { @class = "form-select" })
                            @Html.ValidationMessageFor(m => m.Role, "", new { @class = "text-danger" })
                        </div>
                        <div class="mb-3">
                            @Html.LabelFor(m => m.Password, "Yeni Şifre (değiştirmek için doldurun)", new { @class = "form-label" })
                            @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Şifreyi değiştir (isteğe bağlı)" })
                            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                        </div>
                        <button type="submit" class="btn btn-warning w-100">Güncelle</button>
                    }

                    <div class="mt-4 text-center">
                        <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-link">← Admin Paneline Dön</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
