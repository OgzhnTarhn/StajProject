@model StajProject.Models.SAPUserModel
@{
    ViewBag.Title = "User Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-0">
    <!-- Hero Section -->
    <div class="bg-gradient-primary text-white py-5 mb-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <h1 class="display-4 fw-bold mb-3">
                        <i class="fas fa-user-circle me-3"></i>User Dashboard
                    </h1>
                    <p class="lead mb-0">
                        Welcome, @Model.Username! 
                        @if (Model.Role == "A")
                        {
                            <span>As an admin, you have access to user management and trip administration.</span>
                        }
                        else
                        {
                            <span>You can manage your account information here.</span>
                        }
                    </p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <div class="d-flex flex-column align-items-lg-end">
                        <span class="badge bg-light text-primary mb-2 px-3 py-2">
                            <i class="fas fa-user-tag me-2"></i>@((@Model.Role == "U") ? "User" : @Model.Role)
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Content Section -->
    <div class="container">
        <div class="row g-4">
            <!-- User Info Card -->
            <div class="col-lg-6">
                <div class="card border-0 shadow h-100">
                    <div class="card-header bg-white border-0 py-4">
                        <h4 class="mb-0">
                            <i class="fas fa-user me-2 text-primary"></i>User Information
                        </h4>
                    </div>
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 80px; height: 80px;">
                                <i class="fas fa-user-circle text-primary" style="font-size: 2.5rem;"></i>
                            </div>
                            <div>
                                <h5 class="mb-1 fw-bold">@Model.Username</h5>
                                <span class="badge bg-info bg-opacity-10 text-info px-3 py-2">
                                    <i class="fas fa-award me-1"></i>@((@Model.Role == "U") ? "User" : @Model.Role)
                                </span>
                            </div>
                        </div>
                        
                        <div class="row g-3">
                            <div class="col-12">
                                <div class="d-flex align-items-center p-3 bg-light rounded">
                                    <i class="fas fa-user text-primary me-3"></i>
                                    <div>
                                        <small class="text-muted d-block">Username</small>
                                        <strong>@Model.Username</strong>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="d-flex align-items-center p-3 bg-light rounded">
                                    <i class="fas fa-shield-alt text-success me-3"></i>
                                    <div>
                                        <small class="text-muted d-block">Role</small>
                                        <strong>@((@Model.Role == "U") ? "User" : @Model.Role)</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Actions Card -->
            <div class="col-lg-6">
                <div class="card border-0 shadow h-100">
                    <div class="card-header bg-white border-0 py-4">
                        <h4 class="mb-0">
                            <i class="fas fa-bolt me-2 text-warning"></i>Quick Actions
                        </h4>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-3">
                            <a href="@Url.Action("Index", "Block")" class="btn btn-primary btn-lg">
                                <i class="fas fa-map-marked-alt me-2"></i>View Trips
                            </a>
                            <a href="@Url.Action("EditProfile", "Account")" class="btn btn-outline-primary btn-lg">
                                <i class="fas fa-user-edit me-2"></i>Edit Profile
                            </a>
                            @if (Model.Role == "A")
                            {
                                <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-outline-success btn-lg">
                                    <i class="fas fa-users me-2"></i>User Management
                                </a>
                            }
                            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-home me-2"></i>Home
                            </a>
                        </div>
                        
                        <hr class="my-4">
                        
                        <div class="text-center">
                            <a href="@Url.Action("Logout", "Account")" class="btn btn-outline-danger btn-lg px-5">
                                <i class="fas fa-sign-out-alt me-2"></i>Logout
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
        {
            <div class="row mt-4">
                <div class="col-12">
                    <div class="alert alert-danger border-0 shadow-sm">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        @ViewBag.ErrorMessage
                    </div>
                </div>
            </div>
        }
    </div>
</div>
