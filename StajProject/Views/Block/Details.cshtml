@model StajProject.Models.BlockVm

@{
    ViewBag.Title = "Trip Details";
}

<div class="container-fluid px-0">
    <!-- Anti-forgery token for delete operations -->
    @Html.AntiForgeryToken()

    <!-- Hero Section -->
    <div class="bg-gradient-primary text-white py-5 mb-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <h1 class="display-4 fw-bold mb-3">
                        <i class="fas fa-map-marked-alt me-3"></i>
                        @if (Model.Headers != null && Model.Headers.Count > 0)
                        {
                            @Model.Headers[0].Title
                        }
                        else
                        {
                            <span>Trip Details</span>
                        }
                    </h1>
                    <p class="lead mb-0">You can view all the details of your trip plan here.</p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    @if (Session["Role"] != null && Session["Role"].ToString() == "A")
                    {
                        <div class="btn-group" role="group">
                            <a href="@Url.Action("Edit", "Block", new { id = Model.Headers[0].BlockId })" class="btn btn-light btn-lg" title="Edit Trip">
                                <i class="fas fa-edit me-2"></i>Edit
                            </a>
                            <button class="btn btn-outline-light btn-lg"
                                    onclick="deleteTrip('@Model.Headers[0].BlockId', '@Model.Headers[0].Title')"
                                    title="Delete Trip">
                                <i class="fas fa-trash me-2"></i>Delete
                            </button>
                        </div>
                    }
                    else
                    {
                        <span class="text-white-50">
                            <i class="fas fa-lock me-2"></i>Only Admin Can Edit
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Content Section -->
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <!-- Gezi Detayları -->
                <div class="card border-0 shadow mb-4">
                    <div class="card-header bg-white border-0 py-4">
                        <h3 class="mb-0">
                            <i class="fas fa-list me-2 text-primary"></i>Trip Details
                        </h3>
                    </div>
                    <div class="card-body p-0">
                        @if (Model.Details != null && Model.Details.Count > 0)
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="border-0 px-4 py-3" style="width: 80px;">
                                                <i class="fas fa-hashtag me-2 text-primary"></i>Order
                                            </th>
                                            <th class="border-0 px-4 py-3">
                                                <i class="fas fa-info-circle me-2 text-primary"></i>Details
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var detail in Model.Details)
                                        {
                                            <tr>
                                                <td class="px-4 py-3">
                                                    <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2">
                                                        @detail.SeqNo
                                                    </span>
                                                </td>
                                                <td class="px-4 py-3">
                                                    <div class="d-flex align-items-center">
                                                        <div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                                            <i class="fas fa-map-marker-alt text-success"></i>
                                                        </div>
                                                        <div>
                                                            <h6 class="mb-0">@detail.LineText</h6>
                                                            <small class="text-muted">ID: @detail.DetailId</small>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <div class="mb-4">
                                    <i class="fas fa-exclamation-triangle text-warning" style="font-size: 64px;"></i>
                                </div>
                                <h4 class="text-warning mb-3">Detay Bulunamadı</h4>
                                <p class="text-muted mb-0">Bu gezi için henüz detay bilgisi eklenmemiş.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <!-- Trip Information -->
                <div class="card border-0 shadow mb-4">
                    <div class="card-header bg-white border-0 py-4">
                        <h5 class="mb-0">
                            <i class="fas fa-info-circle me-2 text-info"></i>Trip Information
                        </h5>
                    </div>
                    <div class="card-body">
                        @if (Model.Headers != null && Model.Headers.Count > 0)
                        {
                            var header = Model.Headers[0];
                            <div class="mb-3">
                                <label class="form-label text-muted small">Block ID</label>
                                <p class="mb-0 fw-bold">@header.BlockId</p>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-muted small">City Code</label>
                                <p class="mb-0 fw-bold">
                                    <span class="badge bg-primary bg-opacity-10 text-primary">
                                        <i class="fas fa-map-marker-alt me-1"></i>@header.IlKodu
                                    </span>
                                </p>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-muted small">Mandant</label>
                                <p class="mb-0 fw-bold">@header.Mandt</p>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-muted small">Creation Date</label>
                                <p class="mb-0 fw-bold">
                                    @if (!string.IsNullOrWhiteSpace(header.Erdat))
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success">
                                            <i class="fas fa-calendar me-1"></i>@header.Erdat
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not Specified</span>
                                    }
                                </p>
                            </div>
                            <div class="mb-0">
                                <label class="form-label text-muted small">Last Update</label>
                                <p class="mb-0 fw-bold">
                                    @if (!string.IsNullOrWhiteSpace(header.Aedat) && header.Aedat != "0000-00-00")
                                    {
                                        <span class="badge bg-info bg-opacity-10 text-info">
                                            <i class="fas fa-edit me-1"></i>@header.Aedat
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not Updated</span>
                                    }
                                </p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Statistics -->
                <div class="card border-0 shadow">
                    <div class="card-header bg-white border-0 py-4">
                        <h5 class="mb-0">
                            <i class="fas fa-chart-bar me-2 text-success"></i>Statistics
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-6">
                                <div class="mb-3">
                                    <h3 class="text-primary mb-1">@(Model.Details?.Count ?? 0)</h3>
                                    <small class="text-muted">Total Details</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="mb-3">
                                    <h3 class="text-success mb-1">@(Model.Headers?.Count ?? 0)</h3>
                                    <small class="text-muted">Headers</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Geri Dön Butonu -->
        <div class="text-center mt-5">
            <a href="@Url.Action("Index", "Block")" class="btn btn-outline-primary btn-lg">
                <i class="fas fa-arrow-left me-2"></i>Return to Trips
            </a>
        </div>
    </div>
</div>

<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .text-white {
        color: #ffffff !important;
    }

    .lead {
        color: #ffffff !important;
        font-weight: 500;
    }

    .display-4 {
        color: #ffffff !important;
        font-weight: 700;
    }

    .card {
        border-radius: 15px;
    }

    .table > :not(caption) > * > * {
        border-bottom: 1px solid rgba(0,0,0,.05);
    }

    .table-hover > tbody > tr:hover {
        background-color: rgba(0,0,0,.02);
    }

    .badge {
        font-size: 0.85rem;
    }
</style>

@section scripts {
    <script>
        function deleteTrip(blockId, title) {
            if (confirm('Are you sure you want to delete the trip "' + title + '"?\n\nThis action cannot be undone.')) {
                // Create a form to submit the delete request
                var form = document.createElement('form');
                form.method = 'POST';
                form.action = '@Url.Action("Delete", "Block")';

                // Add anti-forgery token
                var token = document.createElement('input');
                token.type = 'hidden';
                token.name = '__RequestVerificationToken';
                token.value = $('input[name="__RequestVerificationToken"]').val();
                form.appendChild(token);

                // Add block ID
                var idInput = document.createElement('input');
                idInput.type = 'hidden';
                idInput.name = 'id';
                idInput.value = blockId;
                form.appendChild(idInput);

                // Submit the form
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}
