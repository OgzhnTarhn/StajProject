@model List<StajProject.Models.BlockHeaderModel>

@{
    ViewBag.Title = "Geziler";
}

@functions{
    // SAP DATS → dd.MM.yyyy
    string SapDate(string d)
    {
        if (string.IsNullOrWhiteSpace(d) || d.Length != 8) return "";
        return $"{d.Substring(6, 2)}.{d.Substring(4, 2)}.{d.Substring(0, 4)}";
    }
}

<h2>Geziler</h2>

@if (Model == null || Model.Count == 0)
{
    <div class="alert alert-info">Listelenecek gezi bulunamadı.</div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Başlık</th>
                <th>Oluşturma Tarihi</th>
                <th>Güncelleme Tarihi</th>
                <th style="width:120px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@SapDate(item.Erdat)</td>
                    <td>@SapDate(item.Aedat)</td>
                    <td>
                        <a class="btn btn-primary btn-sm"
                           href="@Url.Action("Details", "Block", new { id = item.BlockId })">
                            Detay
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
