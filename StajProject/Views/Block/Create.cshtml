@model StajProject.Models.CreateBlockVm

@{
    ViewBag.Title = "Yeni Gezi Oluştur";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Admin Check -->
            @if (Session["Role"] == null || Session["Role"].ToString() != "A")
            {
                <div class="alert alert-danger text-center" role="alert">
                    <i class="fas fa-exclamation-triangle fa-2x mb-3"></i>
                    <h4 class="alert-heading">Access Denied!</h4>
                    <p class="mb-0">Only admin users can access this page.</p>
                    <hr>
                    <a href="@Url.Action("Index", "Block")" class="btn btn-outline-danger">
                        <i class="fas fa-arrow-left me-2"></i>Go Back
                    </a>
                </div>
            }
            else
            {
                <!-- Hero Section -->
                <div class="text-center mb-5">
                    <h1 class="display-4 fw-bold text-primary">
                        <i class="fas fa-plus-circle me-3"></i>Create New Trip
                    </h1>
                    <p class="lead text-muted">Fill out the form below to create a new trip plan.</p>
                </div>

                <!-- Form Card -->
                <div class="card border-0 shadow-lg">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="mb-0">
                            <i class="fas fa-map-marked-alt me-2"></i>Trip Information
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        @using (Html.BeginForm("Create", "Block", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
                        {
                            @Html.AntiForgeryToken()

                            <!-- Title -->
                            <div class="mb-4">
                                <label for="Title" class="form-label fw-bold">
                                    <i class="fas fa-heading me-2 text-primary"></i>Trip Title
                                </label>
                                @Html.TextBoxFor(m => m.Title, new
                                {
                                    @class = "form-control form-control-lg",
                                    placeholder = "Example: Istanbul Trip, Cappadocia Tour...",
                                    required = "required"
                                })
                                @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger" })
                                <div class="form-text">
                                    <i class="fas fa-info-circle me-1"></i>Enter a title that best describes your trip plan.
                                </div>
                            </div>

                            <!-- Il Kodu -->
                            <div class="mb-4">
                                <label for="IlKodu" class="form-label fw-bold">
                                    <i class="fas fa-map-marker-alt me-2 text-primary"></i>City Code
                                </label>
                                @Html.TextBoxFor(m => m.IlKodu, new
                                {
                                    @class = "form-control form-control-lg",
                                    placeholder = "Example: 34, 06, 35...",
                                    required = "required"
                                })
                                @Html.ValidationMessageFor(m => m.IlKodu, "", new { @class = "text-danger" })
                                <div class="form-text">
                                    <i class="fas fa-info-circle me-1"></i>Enter the city code for this trip destination.
                                </div>
                            </div>

                            <!-- Detail Lines -->
                            <div class="mb-4">
                                <label for="DetailLines" class="form-label fw-bold">
                                    <i class="fas fa-list me-2 text-primary"></i>Trip Details
                                </label>
                                @Html.TextAreaFor(m => m.DetailLines, new
                                {
                                    @class = "form-control",
                                    rows = "8",
                                    placeholder = "Write one detail per line... Example: 1. Morning 09:00 - Topkapi Palace"
                                })
                                @Html.ValidationMessageFor(m => m.DetailLines, "", new { @class = "text-danger" })
                                <div class="form-text">
                                    <i class="fas fa-info-circle me-1"></i>Write one trip detail per line. Blank lines will be skipped automatically.
                                </div>
                            </div>

                            <!-- Buttons -->
                            <div class="d-flex justify-content-between align-items-center">
                                <a href="@Url.Action("Index", "Block")" class="btn btn-outline-secondary btn-lg">
                                    <i class="fas fa-arrow-left me-2"></i>Cancel
                                </a>
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-save me-2"></i>Create Trip
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
            <!-- Help Card -->
            <div class="card border-0 shadow-sm mt-4">
                <div class="card-body">
                    <h6 class="card-title text-primary">
                        <i class="fas fa-lightbulb me-2"></i>Tips
                    </h6>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <strong>Title:</strong> Should be short but descriptive
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <strong>Details:</strong> Write one activity per line
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <strong>Time:</strong> Add time information if possible
                        </li>
                        <li class="mb-0">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <strong>Priority:</strong> Write important items first
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

</div>

               
            }
        </div>
    </div>
</div>

<style>
    .card {
        border-radius: 15px;
    }

    .form-control {
        border-radius: 10px;
        border: 2px solid #e9ecef;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
        }

    .btn {
        border-radius: 10px;
        padding: 12px 24px;
        font-weight: 500;
    }

    .alert {
        border-radius: 15px;
    }
</style>

@section scripts {
    <script>
        // Form validation için Bootstrap
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
}
