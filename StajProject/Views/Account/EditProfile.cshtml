@model StajProject.Models.EditUserProfileModel

@{
    ViewBag.Title = "Profili Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container mt-5">
    <h2>Profili Düzenle</h2>
    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-info">@Model.Message</div>
    }
    @using (Html.BeginForm())
    {
        <div class="mb-3">
            <label>Kullanıcı Adı (Mevcut):</label>
            @Html.TextBoxFor(m => m.Username, new { @class = "form-control", @readonly = "readonly" })
        </div>
        <div class="mb-3">
            <label>Eski Şifre (Doğrulama için):</label>
            @Html.PasswordFor(m => m.OldPassword, new { @class = "form-control" })
        </div>
        <div class="mb-3">
            <label>Yeni Kullanıcı Adı (değiştirmek istiyorsan):</label>
            @Html.TextBoxFor(m => m.NewUsername, new { @class = "form-control" })
        </div>
        <div class="mb-3">
            <label>Yeni Şifre (değiştirmek istiyorsan):</label>
            @Html.PasswordFor(m => m.NewPassword, new { @class = "form-control" })
        </div>
        <button type="submit" class="btn btn-primary">Kaydet</button>
        <a href="@Url.Action("UserDashboard", "Account")" class="btn btn-secondary ms-2">Vazgeç</a>
    }
</div>
