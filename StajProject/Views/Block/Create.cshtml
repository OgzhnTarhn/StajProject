@model StajProject.Models.CreateBlockVm

@{
    ViewBag.Title = "Yeni Gezi Oluştur";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Admin Kontrolü -->
            @if (Session["Role"] == null || Session["Role"].ToString() != "A")
            {
                <div class="alert alert-danger text-center" role="alert">
                    <i class="fas fa-exclamation-triangle fa-2x mb-3"></i>
                    <h4 class="alert-heading">Erişim Reddedildi!</h4>
                    <p class="mb-0">Bu sayfaya sadece admin kullanıcılar erişebilir.</p>
                    <hr>
                    <a href="@Url.Action("Index", "Block")" class="btn btn-outline-danger">
                        <i class="fas fa-arrow-left me-2"></i>Geri Dön
                    </a>
                </div>
            }
            else
            {
                <!-- Hero Section -->
                <div class="text-center mb-5">
                    <h1 class="display-4 fw-bold text-primary">
                        <i class="fas fa-plus-circle me-3"></i>Yeni Gezi Oluştur
                    </h1>
                    <p class="lead text-muted">Yeni bir gezi planı oluşturmak için aşağıdaki formu doldurun.</p>
                </div>

                <!-- Form Card -->
                <div class="card border-0 shadow-lg">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="mb-0">
                            <i class="fas fa-map-marked-alt me-2"></i>Gezi Bilgileri
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        @using (Html.BeginForm("Create", "Block", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
                        {
                            @Html.AntiForgeryToken()

                            <!-- Başlık -->
                            <div class="mb-4">
                                <label for="Title" class="form-label fw-bold">
                                    <i class="fas fa-heading me-2 text-primary"></i>Gezi Başlığı
                                </label>
                                @Html.TextBoxFor(m => m.Title, new { 
                                    @class = "form-control form-control-lg", 
                                    placeholder = "Örn: İstanbul Gezisi, Kapadokya Turu...",
                                    required = "required"
                                })
                                @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger" })
                                <div class="form-text">
                                    <i class="fas fa-info-circle me-1"></i>Gezi planınızı en iyi şekilde tanımlayan bir başlık girin.
                                </div>
                            </div>

                            <!-- Detay Satırları -->
                            <div class="mb-4">
                                <label for="DetailLines" class="form-label fw-bold">
                                    <i class="fas fa-list me-2 text-primary"></i>Gezi Detayları
                                </label>
                                @Html.TextAreaFor(m => m.DetailLines, new { 
                                    @class = "form-control", 
                                    rows = "8",
                                    placeholder = "Her satıra bir detay yazın...&#10;&#10;Örnek:&#10;1. Sabah 09:00 - Topkapı Sarayı&#10;2. Öğle 12:00 - Sultanahmet Camii&#10;3. Öğleden sonra 15:00 - Ayasofya&#10;4. Akşam 18:00 - Kapalı Çarşı"
                                })
                                @Html.ValidationMessageFor(m => m.DetailLines, "", new { @class = "text-danger" })
                                <div class="form-text">
                                    <i class="fas fa-info-circle me-1"></i>Her satıra bir gezi detayı yazın. Boş satırlar otomatik olarak atlanacaktır.
                                </div>
                            </div>

                            <!-- Butonlar -->
                            <div class="d-flex justify-content-between align-items-center">
                                <a href="@Url.Action("Index", "Block")" class="btn btn-outline-secondary btn-lg">
                                    <i class="fas fa-arrow-left me-2"></i>İptal
                                </a>
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-save me-2"></i>Gezi Oluştur
                                </button>
                            </div>
                        }
                    </div>
                </div>

                <!-- Yardım Kartı -->
                <div class="card border-0 shadow-sm mt-4">
                    <div class="card-body">
                        <h6 class="card-title text-primary">
                            <i class="fas fa-lightbulb me-2"></i>İpuçları
                        </h6>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <i class="fas fa-check-circle text-success me-2"></i>
                                <strong>Başlık:</strong> Kısa ama açıklayıcı olmalı
                            </li>
                            <li class="mb-2">
                                <i class="fas fa-check-circle text-success me-2"></i>
                                <strong>Detaylar:</strong> Her satıra bir aktivite yazın
                            </li>
                            <li class="mb-2">
                                <i class="fas fa-check-circle text-success me-2"></i>
                                <strong>Zaman:</strong> Mümkünse saat bilgisi ekleyin
                            </li>
                            <li class="mb-0">
                                <i class="fas fa-check-circle text-success me-2"></i>
                                <strong>Öncelik:</strong> Önemli yerleri önce yazın
                            </li>
                        </ul>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
.card {
    border-radius: 15px;
}

.form-control {
    border-radius: 10px;
    border: 2px solid #e9ecef;
    transition: all 0.3s ease;
}

.form-control:focus {
    border-color: #0d6efd;
    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
}

.btn {
    border-radius: 10px;
    padding: 12px 24px;
    font-weight: 500;
}

.alert {
    border-radius: 15px;
}
</style>

@section scripts {
    <script>
        // Form validation için Bootstrap
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
}
