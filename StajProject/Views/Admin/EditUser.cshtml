@model StajProject.Models.EditUserProfileModel

@{
    ViewBag.Title = "Kullanıcı Rolü Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container mt-5">
    <h2>Kullanıcı Rolü Düzenle</h2>
    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-info">@Model.Message</div>
    }
    @using (Html.BeginForm())
    {
        <div class="mb-3">
            <label>Kullanıcı Adı:</label>
            @Html.TextBoxFor(m => m.Username, new { @class = "form-control", @readonly = "readonly" })
        </div>
        <div class="mb-3">
            <label>Rol:</label>
            @Html.DropDownListFor(m => m.Role, new SelectList(new[] { new { Value = "A", Text = "Admin" }, new { Value = "U", Text = "User" } }, "Value", "Text"), new { @class = "form-select" })
        </div>
        <button type="submit" class="btn btn-primary">Kaydet</button>
        <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-secondary ms-2">Vazgeç</a>
    }
</div>
