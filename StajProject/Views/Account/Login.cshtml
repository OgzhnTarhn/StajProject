@model StajProject.Models.LoginModel
@{
    ViewBag.Title = "SAP Login";
    Layout = null; //"~/Views/Shared/_Layout.cshtml"; // Layout kullanmıyorsan bu satırı silebilirsin
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

<div class="container mt-5" style="max-width:400px;">
    <div class="card shadow">
        <div class="card-body">
            <h3 class="mb-4 text-center">SAP Login</h3>

            @* Hata mesajlarını göster *@
            @if (!ViewData.ModelState.IsValid)
            {
                foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div class="alert alert-danger">@error.ErrorMessage</div>
                }
            }

            @using (Html.BeginForm())
            {
                <div class="mb-3">
                    @Html.LabelFor(m => m.Username, "Kullanıcı Adı")
                    @Html.TextBoxFor(m => m.Username, new { @class = "form-control", placeholder = "Kullanıcı Adınızı girin", autofocus = "autofocus" })
                </div>
                <div class="mb-3">
                    @Html.LabelFor(m => m.Password, "Şifre")
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Şifrenizi girin" })
                </div>
                <button type="submit" class="btn btn-primary w-100">Giriş Yap</button>
            }
        </div>
    </div>
</div>
