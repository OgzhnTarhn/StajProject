@model StajProject.Models.LoginModel

@{
    ViewBag.Title = "Giriş Yap";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-center align-items-center vh-100 bg-light">
    <div class="card shadow" style="min-width:350px; max-width:400px; width:100%;">
        <div class="card-body p-4">
            <h2 class="mb-4 text-center">Giriş Yap</h2>
            @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
            {
                <div class="alert alert-danger text-center">@ViewBag.ErrorMessage</div>
            }
            @using (Html.BeginForm())
            {
                @Html.ValidationSummary(true, "", new { @class = "alert alert-danger text-center" })
                <div class="mb-3">
                    @Html.LabelFor(m => m.Username, "Kullanıcı Adı", htmlAttributes: new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Username, new { @class = "form-control", placeholder = "Kullanıcı adınızı girin" })
                    @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger" })
                </div>
                <div class="mb-3">
                    @Html.LabelFor(m => m.Password, "Şifre", htmlAttributes: new { @class = "form-label" })
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Şifrenizi girin" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                </div>
                <button type="submit" class="btn btn-primary w-100">Giriş Yap</button>
            }
            <div class="mt-3 text-center">
                <span>Hesabın yok mu?</span>
                <a href="@Url.Action("Register", "Account")" class="btn btn-link">Kayıt Ol</a>
            </div>
        </div>
    </div>
</div>
